{
  "appId": "com.schoolpickup.app",
  "appName": "School Pickup",
  "webDir": "dist",
  "server": {
    "url": "https://school-pickup-t3lc.vercel.app",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1565C0",
      "showSpinner": true,
      "spinnerColor": "#ffffff"
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#1565C0"
    }
  },
  "android": {
    "allowMixedContent": true
  }
}
