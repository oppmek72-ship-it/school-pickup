generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// ຫ້ອງຮຽນ
// ===========================
model Classroom {
  id          Int       @id @default(autoincrement())
  className   String    // ເຊັ່ນ: "ຫ້ອງ ປ.1/1"
  gradeLevel  String    // ເຊັ່ນ: "ປ.1", "ມ.3"
  classCode   String    @unique // "P1-1", "M3-2"
  teacherName String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  students    Student[]
  users       User[]
}

// ===========================
// ຜູ້ໃຊ້
// ===========================
model User {
  id          Int       @id @default(autoincrement())
  name        String
  phone       String?   @unique
  username    String?   @unique
  role        Role      @default(parent)
  password    String
  classroomId Int?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  pickupRequests  PickupRequest[]
  notifications   Notification[]
  historyAsParent PickupHistory[] @relation("HistoryParent")
  historyAsTeacher PickupHistory[] @relation("HistoryTeacher")
}

enum Role {
  parent
  teacher
  admin
}

// ===========================
// ນັກຮຽນ
// ===========================
model Student {
  id          Int           @id @default(autoincrement())
  studentCode String        @unique  // STD-0001
  firstName   String
  lastName    String
  nickname    String?
  classroomId Int?
  classroom   Classroom?    @relation(fields: [classroomId], references: [id])
  photo          String?
  voiceRecording String?  @db.Text  // base64 audio data URL
  parentPhone    String?
  parentName  String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  pickupRequests PickupRequest[]
  pickupHistory  PickupHistory[]
}

// ===========================
// ຄຳຮ້ອງຂໍຮັບນັກຮຽນ
// ===========================
model PickupRequest {
  id            Int           @id @default(autoincrement())
  studentId     Int
  student       Student       @relation(fields: [studentId], references: [id])
  parentId      Int?
  parent        User?         @relation(fields: [parentId], references: [id])
  callType      CallType      @default(arrived)
  status        PickupStatus  @default(waiting)
  calledAt      DateTime      @default(now())
  announcedAt   DateTime?
  pickedUpAt    DateTime?
  expiresAt     DateTime?
  queuePosition Int?
  carPlate      String?
  carColor      String?
  notes         String?
}

enum CallType {
  five_minutes
  ten_minutes
  arrived
}

enum PickupStatus {
  waiting
  announced
  picked_up
  cancelled
}

// ===========================
// ປະຫວັດການຮັບ
// ===========================
model PickupHistory {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  parentId    Int
  parent      User     @relation("HistoryParent", fields: [parentId], references: [id])
  teacherId   Int?
  teacher     User?    @relation("HistoryTeacher", fields: [teacherId], references: [id])
  callType    String?
  pickupTime  DateTime @default(now())
  carPlate    String?
  notes       String?
}

// ===========================
// ການແຈ້ງເຕືອນ
// ===========================
model Notification {
  id        Int         @id @default(autoincrement())
  userId    Int
  user      User        @relation(fields: [userId], references: [id])
  message   String
  type      NotifType
  status    NotifStatus @default(unread)
  createdAt DateTime    @default(now())
}

enum NotifType {
  pickup_request
  student_ready
  pickup_confirmed
  announcement
}

enum NotifStatus {
  read
  unread
}
