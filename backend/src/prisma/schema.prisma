generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  role      Role     @default(parent)
  password  String
  createdAt DateTime @default(now())

  students         Student[]        @relation("ParentStudents")
  teacherStudents  Student[]        @relation("TeacherStudents")
  pickupRequests   PickupRequest[]  @relation("PickupRequestParent")
  notifications    Notification[]
  historyAsParent  PickupHistory[]  @relation("HistoryParent")
  historyAsTeacher PickupHistory[]  @relation("HistoryTeacher")
}

enum Role {
  parent
  teacher
  admin
}

model Student {
  id        Int    @id @default(autoincrement())
  name      String
  class     String
  photo     String?
  qrCode    String @unique
  status    StudentStatus @default(at_school)

  parentId  Int
  parent    User   @relation("ParentStudents", fields: [parentId], references: [id])

  teacherId Int
  teacher   User   @relation("TeacherStudents", fields: [teacherId], references: [id])

  pickupRequests PickupRequest[]
  pickupHistory  PickupHistory[]
}

enum StudentStatus {
  at_school
  called
  picked_up
}

model PickupRequest {
  id          Int           @id @default(autoincrement())
  studentId   Int
  student     Student       @relation(fields: [studentId], references: [id])
  parentId    Int
  parent      User          @relation("PickupRequestParent", fields: [parentId], references: [id])
  status      PickupStatus  @default(coming)
  eta         Int?
  carPlate    String?
  carColor    String?
  requestTime DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum PickupStatus {
  coming
  arrived
  confirmed
  cancelled
}

model PickupHistory {
  id          Int      @id @default(autoincrement())
  studentId   Int
  student     Student  @relation(fields: [studentId], references: [id])
  parentId    Int
  parent      User     @relation("HistoryParent", fields: [parentId], references: [id])
  teacherId   Int?
  teacher     User?    @relation("HistoryTeacher", fields: [teacherId], references: [id])
  pickupTime  DateTime @default(now())
  carPlate    String?
  notes       String?
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  user      User             @relation(fields: [userId], references: [id])
  message   String
  type      NotifType
  status    NotifStatus      @default(unread)
  createdAt DateTime         @default(now())
}

enum NotifType {
  pickup_request
  student_ready
  pickup_confirmed
  announcement
}

enum NotifStatus {
  read
  unread
}
